# ── Polygon 钱包（实盘必填，纸面交易可留空）──
PRIVATE_KEY=0x你的私钥
WALLET_ADDRESS=0x你的钱包地址

# ── Polymarket API ──
POLYMARKET_HOST=https://clob.polymarket.com
CHAIN_ID=137

# ── Telegram 告警（可选，留空则只打印日志）──
TELEGRAM_BOT_TOKEN=你的BotToken
TELEGRAM_CHAT_ID=你的ChatID
# 机器别名：多机部署时区分消息来源（如 "Mac主力" / "VPS-A" / "云服务器"）
# 留空则自动显示钱包地址后6位
BOT_ALIAS=

# ── 风险参数（按需修改）──
MAX_BET_FRACTION=0.20       # 单笔最大仓位（总资金的比例）
MAX_BET_USDC=5              # 实盘单笔最大注额（USDC 硬上限）
MAX_DAILY_LOSS_FRACTION=0.30 # 日最大亏损比例
# 贪婪指数（1~10）：控制策略冒险程度
#   1=极保守（胜率~98%，~3信号/天）
#   5=平衡（胜率~94%，~40信号/天，推荐）
#   10=极激进（胜率~80%，~160信号/天）
GREED_INDEX=5
MIN_EV_THRESHOLD=0.08        # 最低期望收益阈值（被GREED_INDEX动态覆盖）
MIN_GAP_PCT=0.10             # 触发信号的最小价格差距（%）
ENTRY_MARGIN=0.03            # 理论胜率 - 市场赔率 的最小安全边际

# ── 运行模式 ──
# paper = 纸面交易（默认），live = 实盘
MODE=paper

# ── 网络代理（可选）──
# 留空则直连；如有网络问题（SSL错误/连接超时），可配置代理
# 支持格式：
#   http://127.0.0.1:7890        HTTP 代理
#   socks5://127.0.0.1:1080      SOCKS5 代理（需 pip install PySocks）
#   socks5h://127.0.0.1:1080     SOCKS5 代理（DNS 也走代理，推荐）
PROXY_URL=

# ── 资金归集（可选）──
# 每次兑换成功后，若余额达到阈值，自动转出 阈值×比例 到归集钱包
# 示例：余额=$120，阈值=$50，比例=0.8 → 转出 50×0.8=$40，保留$80
# 留空 SWEEP_WALLET 或 SWEEP_THRESHOLD=0 则禁用
SWEEP_WALLET=                   # 归集目标钱包地址（留空=禁用）
SWEEP_THRESHOLD=0               # 触发归集的余额阈值（USDC，0=禁用）
SWEEP_RATIO=0.8                 # 归集比例（0.0~1.0，转出 阈值×比例 的金额）

# ── 日盈利目标（北京时间自然日）──
# 当日已实现盈亏累计 ≥ 此值（USDC）时：停止下单，并将 min(累计盈利, 余额−保留) 转至 SWEEP_WALLET
# 次日北京时间 0 点后自动恢复下单；0=关闭本功能
DAILY_PROFIT_TARGET_USDC=0
DAILY_PROFIT_RESERVE_USDC=3     # 归集后钱包至少保留 USDC（gas/次日）
