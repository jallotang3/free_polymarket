# ── Polygon 钱包（实盘必填，纸面交易可留空）──
PRIVATE_KEY=0x你的私钥
WALLET_ADDRESS=0x你的钱包地址

# ── Polymarket API ──
POLYMARKET_HOST=https://clob.polymarket.com
CHAIN_ID=137

# ── Telegram 告警（可选，留空则只打印日志）──
TELEGRAM_BOT_TOKEN=你的BotToken
TELEGRAM_CHAT_ID=你的ChatID

# ── 风险参数（按需修改）──
MAX_BET_FRACTION=0.05       # 单笔最大仓位（总资金的比例）
MAX_DAILY_LOSS_FRACTION=0.15 # 日最大亏损比例
MIN_EV_THRESHOLD=0.02        # 最低期望收益阈值
MIN_GAP_PCT=0.10             # 触发信号的最小价格差距（%）
ENTRY_MARGIN=0.03            # 理论胜率 - 市场赔率 的最小安全边际

# ── 运行模式 ──
# paper = 纸面交易（默认），live = 实盘
MODE=paper

# ── 网络代理（可选）──
# 留空则直连；如有网络问题（SSL错误/连接超时），可配置代理
# 支持格式：
#   http://127.0.0.1:7890        HTTP 代理
#   socks5://127.0.0.1:1080      SOCKS5 代理（需 pip install PySocks）
#   socks5h://127.0.0.1:1080     SOCKS5 代理（DNS 也走代理，推荐）
PROXY_URL=
